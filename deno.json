{
  "nodeModulesDir": "auto",
  "tasks": {
    "check": "deno lint . && deno check",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "test-browser": "deno run -A tests/run.ts"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@/": "./",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "fresh": "jsr:@fresh/core@^2.2.0",
    "preact": "npm:preact@^10.28.4",
    "preact/compat": "npm:preact@^10.28.4/compat",
    "react": "npm:preact@^10.28.4/compat",
    "react-dom": "npm:preact@^10.28.4/compat",
    "react-day-picker": "npm:react-day-picker@^9.14.0",
    "date-fns": "npm:date-fns@^4.1.0",
    "@preact/signals": "npm:@preact/signals@^2.8.1",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "vite": "npm:vite@7.3.1",
    "tailwindcss": "npm:tailwindcss@^4.2.1",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.1",
    "vite-plugin-pwa": "npm:vite-plugin-pwa@^1.2.0",
    "z3-solver": "npm:z3-solver@4.16.0",
    "@sigmasd/vite-plugin-z3": "jsr:@sigmasd/vite-plugin-z3@^0.7.0",
    "@sigmasd/vite-plugin-z3/runtime": "jsr:@sigmasd/vite-plugin-z3@^0.7.0/runtime"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  },
  "deploy": {
    "project": "5927836e-9992-441a-83f7-68bea44f1bd8",
    "exclude": [
      "**/node_modules"
    ],
    "include": ["_fresh"],
    "entrypoint": "_fresh/server.js"
  }
}
